
# ─── External API Keys ───────────────────────────────────────────────────────
# Sign up at https://openweathermap.org/api to get a free key
OPENWEATHER_API_KEY=your_openweather_api_key

# Amadeus self-service portal is decommissioned — using FlightAPI.io instead
# Sign up at https://flightapi.io to get a free key
FLIGHTAPI_KEY=your_flightapi_key

# OpenTripMap dropped (registration verification issues) — using GeoNames instead.
# Register a free account at https://www.geonames.org/login, then enable free
# web services at https://www.geonames.org/manageaccount
GEONAMES_USERNAME=your_geonames_username

# Sign up at https://www.exchangerate-api.com to get a free key
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# ─── Voice Layer ─────────────────────────────────────────────────────────────
# Sign up at https://www.sarvam.ai to get a key (primary STT/TTS)
SARVAM_API_KEY=your_sarvam_api_key

# Sign up at https://deepgram.com to get a key (fallback STT/TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── LLM Layer ───────────────────────────────────────────────────────────────
# Sign up at https://console.groq.com to get a free key (fallback LLM — openai/gpt-oss-120b)
GROQ_API_KEY=your_groq_api_key

# Ollama must be running locally — run: ollama pull qwen3.5:122b && ollama serve
# API key is required when accessing a hosted/remote Ollama endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:122b
OLLAMA_API_KEY=your_ollama_api_key

# ─── Middleware Tuning ────────────────────────────────────────────────────────
# Number of past conversation turns to inject into the prompt
PRE_MODEL_HISTORY_WINDOW=3

# Max characters in TTS response before truncation kicks in
POST_MODEL_MAX_CHARS=400

# Suffix appended when a response is truncated
POST_MODEL_OVERFLOW_SUFFIX=...for more details, just ask

# Sarvam retry attempts before falling back to Deepgram (0 = try once, then fallback)
VOICE_MAX_RETRIES=2
